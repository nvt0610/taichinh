# Production Environment Variables
# Copy file này -> .env rồi điền giá trị thật vào

# Database
DB_NAME=taichinh_db
DB_USERNAME=taichinh_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (bắt buộc đổi thành chuỗi random dài >= 64 ký tự)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_64_CHARS

# CORS
CORS_ORIGINS=http://your-domain.com
