# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=taichinh_db
DB_USERNAME=taichinh_user
DB_PASSWORD=taichinh_pass

# Server
SERVER_PORT=8080

# JWT (thay bằng chuỗi ngẫu nhiên dài >= 32 ký tự trong production)
JWT_SECRET=taichinh-super-secret-key-change-in-production-min-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS
CORS_ORIGINS=http://localhost:3000
